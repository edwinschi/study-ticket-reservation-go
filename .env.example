APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8080
COOKIE_SECURE=false
VISITOR_SESSION_TTL=720h
RESERVATION_TTL=15m
EXPIRATION_WORKER_INTERVAL=5s
EXPIRATION_WORKER_BATCH_SIZE=100

POSTGRES_DB=ticket_reservation_go
POSTGRES_USER=ticket_reservation_go
POSTGRES_PASSWORD=ticket_reservation_go
POSTGRES_PORT=5433

STARTUP_TIMEOUT=10s
READINESS_TIMEOUT=2s
SHUTDOWN_TIMEOUT=10s

# Docker Compose configures DATABASE_URL and REDIS_ADDR on the internal network.
